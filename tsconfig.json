{
    "extends": "expo/tsconfig.base",
    "compilerOptions": {
        "strict": true,
        "baseUrl": ".",
        "paths": {
            "components/*": ["components/*"],
            "navigation/*": ["navigation/*"],
            "screens/*": ["screens/*"],
            "stores/*": ["stores/*"],
            "types/*": ["types/*"],
            "utils/*": ["utils/*"]
        }
    },
    "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"]
}
